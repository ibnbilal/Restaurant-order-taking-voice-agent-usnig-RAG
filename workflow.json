    {
      "parameters": {
        "jsCode": "// ADDED: Phone formatter helper function (placed at the top)\nfunction formatPhoneNumber(raw, defaultCountry = 'PK') {\n  const COUNTRY_CODES = {\n    PK: '92',\n    US: '1',\n    UK: '44',\n    IN: '91',\n    AE: '971',\n    CA: '1',\n    AU: '61'\n  };\n\n  if (!raw) return null;\n\n  let cleaned = String(raw).replace(/[^\\d+]/g, '');\n\n  if (cleaned.startsWith('+')) return cleaned;\n\n  if (cleaned.startsWith('0')) {\n    cleaned = cleaned.substring(1);\n  }\n\n  const code = COUNTRY_CODES[defaultCountry] || '92';\n\n  if (cleaned.startsWith(code)) {\n    return '+' + cleaned;\n  }\n\n  return '+' + code + cleaned;\n}\n\n// 1. Grab the array of tool calls from the incoming webhook\nconst toolCalls = $input.item.json.body.message.toolCalls;\n\n// 2. Map through each call to clean up the \"arguments\"\nconst cleanedData = toolCalls.map(call => {\n  let args = call.function.arguments;\n\n  // If arguments are a string, parse them into a real JSON object\n  if (typeof args === 'string') {\n    try {\n      args = JSON.parse(args);\n    } catch (e) {\n      args = { error: \"Could not parse arguments\" };\n    }\n  }\n\n  // ADDED: Phone cleaning logic (after parsing arguments)\n  if (args.phone) {\n    args.phone = formatPhoneNumber(args.phone);\n  }\n\n  return {\n    toolCallId: call.id,\n    functionName: call.function.name,\n    ...args\n  };\n});\n\n// 3. Return the cleaned list back to n8n\nreturn cleanedData;"
      },
