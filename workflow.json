        "subject": "=New order from  {{ $('Code in JavaScript').item.json.name }}",
        "emailType": "html",
        "message": "=<!DOCTYPE html>\n<html>\n<head>\n  <meta charset=\"UTF-8\" />\n  <title>New Order</title>\n</head>\n\n<body style=\"margin:0; padding:0; background:#f5f6f8; font-family:Arial, sans-serif;\">\n\n  <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"padding:30px 0;\">\n    <tr>\n      <td align=\"center\">\n\n        <!-- Card -->\n        <table width=\"600\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#ffffff; border-radius:12px; overflow:hidden; box-shadow:0 10px 30px rgba(0,0,0,0.08);\">\n\n          <!-- Header -->\n          <tr>\n            <td style=\"background:#111827; padding:22px; text-align:center;\">\n              <h2 style=\"margin:0; color:#ffffff; font-size:20px; letter-spacing:0.5px;\">\n                🍽️ New Order Received\n              </h2>\n            </td>\n          </tr>\n\n          <!-- Body -->\n          <tr>\n            <td style=\"padding:25px; color:#111827;\">\n\n              <p style=\"margin:0 0 20px 0; font-size:14px; color:#6b7280;\">\n                You have received a new customer order. Please find the details below.\n              </p>\n\n              <!-- Customer Info -->\n              <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"margin-bottom:20px; font-size:14px;\">\n                <tr>\n                  <td style=\"padding:6px 0; color:#6b7280; width:160px;\">Customer Name</td>\n                  <td style=\"padding:6px 0; color:#111827; font-weight:600;\">\n                    {{ $('Code in JavaScript').item.json.name }}\n                  </td>\n                </tr>\n\n                <tr>\n                  <td style=\"padding:6px 0; color:#6b7280;\">Phone</td>\n                  <td style=\"padding:6px 0; color:#111827;\">\n                    {{ $('Code in JavaScript').item.json.phone }}\n                  </td>\n                </tr>\n\n                <tr>\n                  <td style=\"padding:6px 0; color:#6b7280;\">Address</td>\n                  <td style=\"padding:6px 0; color:#111827;\">\n                    {{ $('Code in JavaScript').item.json.address }}\n                  </td>\n                </tr>\n\n                <tr>\n                  <td style=\"padding:6px 0; color:#6b7280;\">Special Notes</td>\n                  <td style=\"padding:6px 0; color:#111827;\">\n                    {{ $('Code in JavaScript').item.json.special_info }}\n                  </td>\n                </tr>\n              </table>\n\n              <!-- Order Box -->\n              <div style=\"background:#f9fafb; border:1px solid #e5e7eb; border-radius:10px; padding:16px;\">\n\n                <p style=\"margin:0 0 8px 0; font-size:13px; color:#6b7280;\">\n                  Order Details\n                </p>\n\n                <div style=\"font-size:14px; color:#111827; font-weight:500;\">\n                  {{ $('Code in JavaScript').item.json.what_to_order }}\n                </div>\n\n              </div>\n\n              <!-- Footer note -->\n              <p style=\"margin-top:22px; font-size:12px; color:#9ca3af;\">\n                Please prepare the order and proceed with fulfillment.\n              </p>\n\n            </td>\n          </tr>\n\n          <!-- Footer -->\n          <tr>\n            <td style=\"background:#f3f4f6; text-align:center; padding:12px; font-size:11px; color:#9ca3af;\">\n              Automated notification system\n            </td>\n          </tr>\n\n        </table>\n\n      </td>\n    </tr>\n  </table>\n\n</body>\n</html>",
